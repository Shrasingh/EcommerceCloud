# ─────────────────────────────────────────────────────────────
# EcommerceCloud (Admin Dashboard) — environment variables
# Copy this file to `.env` and fill in real values.
# ─────────────────────────────────────────────────────────────

# ── Clerk authentication ── (https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# ── Database (PostgreSQL) ──
# Neon (recommended): https://neon.tech  — use the pooled connection string.
# IMPORTANT: URL-encode special characters in the password (e.g. `@` -> `%40`).
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"
# Direct (non-pooled) connection — used by Prisma migrations. For Neon use the
# same host without `-pooler`, or reuse DATABASE_URL if you have no pooled URL.
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# ── Cloudinary (image uploads) ── (https://cloudinary.com)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your_cloud_name"

# ── Stripe (payments) ── (https://dashboard.stripe.com/test/apikeys)
STRIPE_API_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Storefront URL ── (where QuickCart runs; used for Stripe redirect URLs)
FRONTEND_STORE_URL=http://localhost:3001

# ── Seed script (optional) ──
# Set this to your Clerk user id so the seeded demo store shows up in the
# admin dashboard for your account. Find it in the Clerk dashboard > Users.
SEED_STORE_OWNER_ID=
